# syntax=docker/dockerfile:1

FROM mcr.microsoft.com/playwright/python:v1.58.0-jammy

WORKDIR /app
RUN pip install --no-cache-dir playwright==1.58.0
COPY scripts/ ./scripts/

EXPOSE 8080

CMD ["sh", "-lc", "xvfb-run -a --server-args='-screen 0 1920x1080x24 -nolisten tcp' python3 scripts/browser_launcher.py watch --dir /runtime/browser-launch-requests"]
